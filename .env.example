# Port Express listens on locally (Railway sets this for you in production)
PORT=3000

# --- Agent protection (server-to-server callers only) ---
# Optional shared secret for calling /agent/run directly with a x-api-key
# header instead of a browser session. Leave blank for local testing.
AGENT_API_KEY=

# --- AI calls (NVIDIA NIM, OpenAI-compatible) ---
NIM_API_BASE=https://integrate.api.nvidia.com/v1
NIM_API_KEY=
NIM_MODEL=qwen/qwen2.5-coder-32b-instruct

# --- GitHub OAuth App (for the "Connect GitHub" button in the UI) ---
# Register at https://github.com/settings/developers
# Authorization callback URL must be: ${APP_BASE_URL}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Public URL this app is deployed at, e.g. https://your-app.up.railway.app
# Leave blank locally — it will be inferred from the incoming request.
APP_BASE_URL=

# --- Fallback GitHub token (optional) ---
# Used only if a request has no browser session and no per-request token
# (e.g. calling /agent/run directly with AGENT_API_KEY).
GITHUB_TOKEN=
